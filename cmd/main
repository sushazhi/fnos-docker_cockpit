#!/bin/bash

APP_NAME="dockpit"
LOG_FILE="${TRIM_PKGVAR}/info.log"
PID_FILE="${TRIM_PKGVAR}/app.pid"
APP_DIR="${TRIM_APPDEST}"

PORT="${wizard_app_port:-${TRIM_SERVICE_PORT:-8807}}"

log_msg() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $1" >> ${LOG_FILE}
}

start_process() {
    if status; then
        log_msg "$APP_NAME is already running"
        return 0
    fi
    
    log_msg "Starting $APP_NAME on port $PORT..."
    
    mkdir -p "${TRIM_PKGVAR}"
    
    cd "$APP_DIR"
    
    PORT=$PORT DPANEL_DATA_DIR="${TRIM_PKGVAR}" ./server/dockpit >> ${LOG_FILE} 2>&1 &
    printf "%s" "$!" > "$PID_FILE"
    
    sleep 2
    
    if check_process "$(cat $PID_FILE 2>/dev/null)"; then
        log_msg "$APP_NAME started successfully on port $PORT"
        echo ""
        echo "=========================================="
        echo "  Dockpit 已启动"
        echo "  端口: $PORT"
        echo "  访问地址: http://<IP>:$PORT/"
        echo "  数据目录: ${TRIM_PKGVAR}"
        echo "  日志: cat ${TRIM_PKGVAR}/info.log"
        echo "=========================================="
        echo ""
        return 0
    else
        log_msg "Failed to start $APP_NAME"
        return 1
    fi
}

stop_process() {
    log_msg "Stopping $APP_NAME..."
    
    if [ -r "$PID_FILE" ]; then
        pid=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
        
        if ! check_process "$pid"; then
            rm -f "$PID_FILE"
            return 0
        fi
        
        kill -TERM "$pid" >> ${LOG_FILE} 2>&1
        
        local count=0
        while check_process "$pid" && [ $count -lt 10 ]; do
            sleep 1
            count=$((count + 1))
        done
        
        if check_process "$pid"; then
            kill -KILL "$pid" 2>/dev/null
            sleep 1
        fi
        
        rm -f "$PID_FILE"
    fi
    
    log_msg "$APP_NAME stopped"
    return 0
}

check_process() {
    local pid=$1
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
        return 0
    else
        return 1
    fi
}

status() {
    if [ -f "$PID_FILE" ]; then
        pid=$(head -n 1 "$PID_FILE" | tr -d '[:space:]')
        if check_process "$pid"; then
            echo "$APP_NAME is running (PID: $pid)"
            return 0
        else
            rm -f "$PID_FILE"
        fi
    fi
    
    echo "$APP_NAME is not running"
    return 3
}

case "$1" in
    start)
        start_process
        ;;
    stop)
        stop_process
        ;;
    restart)
        stop_process
        sleep 2
        start_process
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac
